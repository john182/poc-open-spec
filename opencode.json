{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "lsp": "allow"
  },
  "watcher": {
    "ignore": [
      ".git/**",
      "**/node_modules/**",
      "**/dist/**",
      "**/bin/**",
      "**/obj/**",
      "**/coverage/**"
    ]
  },
  "mcp": {
    "angular-cli": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@angular/cli",
        "mcp"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    }
  },
  "lsp": {
    "typescript": {
      "command": [
        "typescript-language-server",
        "--stdio"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".mjs",
        ".cjs",
        ".html"
      ],
      "initialization": {
        "preferences": {
          "importModuleSpecifierPreference": "relative"
        }
      }
    },
    "csharp": {
      "command": [
        "csharp-ls"
      ],
      "extensions": [
        ".cs"
      ]
    }
  },
  "instructions": [
    "CLAUDE.md"
  ]
}